<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.emlinha.PrimaryController" style="-fx-background-color: #083c54;">
   <children>
      <Label text="4 em Linha Online" textFill="#ffffff">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      
      <VBox alignment="CENTER_LEFT" maxWidth="250.0" spacing="5.0">
         <children>
            <Label text="O teu Nome:" textFill="#9abccc" />
            <TextField fx:id="txt_player1" promptText="Ex: Ana" style="-fx-background-radius: 15;" />
         </children>
      </VBox>
      
      <VBox alignment="CENTER_LEFT" maxWidth="250.0" spacing="5.0">
         <children>
            <Label text="IP do Adversário (Vazio para Criar Sala):" textFill="#9abccc" />
            <TextField fx:id="txt_player2" promptText="Ex: 192.168.1.X ou localhost" style="-fx-background-radius: 15;" />
         </children>
      </VBox>
      
      <Button fx:id="btn_start" onAction="#btnStartOnAction" text="Iniciar Jogo" style="-fx-background-color: #ffc107; -fx-text-fill: #083c54; -fx-background-radius: 20; -fx-font-weight: bold;" prefWidth="150.0" prefHeight="35.0">
         <font>
            <Font size="14.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
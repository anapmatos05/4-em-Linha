                        <Button fx:id="btnHome" mnemonicParsing="false" onAction="#acaoVoltarMenu" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;" text="🏠" />
                        <Button fx:id="btnPausa" mnemonicParsing="false" onAction="#acaoAlternarPausa" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;" text="⏸" />
                        <Button mnemonicParsing="false" onAction="#acaoJogarDeNovo" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;" text="🔄" />

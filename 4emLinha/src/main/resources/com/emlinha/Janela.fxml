            </Label>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <HBox fx:id="boxAdversario" alignment="CENTER" prefWidth="220.0" spacing="10.0" style="-fx-border-color: transparent; -fx-border-radius: 30; -fx-border-width: 2; -fx-padding: 5 15 5 15;">

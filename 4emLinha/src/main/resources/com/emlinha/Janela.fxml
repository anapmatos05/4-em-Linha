                        <Font size="22.0" />
                     </font>
                  </Label>
                  <Circle fill="#e53935" radius="15.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
               </children>
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </HBox>
         </children>
      </HBox>
   </top>
   <right>
      <StackPane prefWidth="250.0" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="vboxEstatisticas" alignment="TOP_CENTER" spacing="8.0" style="-fx-background-color: #083c54;">
               <children>
                  <Label text="Estado" textFill="#9abccc">
                     <font><Font size="26.0" /></font>
                     <VBox.margin><Insets top="15.0" /></VBox.margin>
                  </Label>
                  <Label text="Turno:" textFill="#9abccc">
                     <font><Font size="16.0" /></font>
                     <VBox.margin><Insets top="5.0" /></VBox.margin>
                  </Label>
                  <Label fx:id="labelTurno" text="Eu" textFill="#ffc107">
                     <font><Font size="22.0" /></font>
                  </Label>
                  <Label text="Peças jogadas:" textFill="#9abccc">
                     <font><Font size="16.0" /></font>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </Label>
                  <Label fx:id="labelPecasEu" text="Eu - 0" textFill="#ffc107">

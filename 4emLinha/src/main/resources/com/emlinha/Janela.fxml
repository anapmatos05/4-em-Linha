               </children>
            </VBox>
            
            <VBox fx:id="vboxVitoria" alignment="CENTER" spacing="20.0" style="-fx-background-color: #083c54;" visible="false">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #357b9c; -fx-border-color: #ffc107; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15;">
                     <padding>
                        <Insets bottom="15.0" left="10.0" right="10.0" top="15.0" />
                     </padding>
                     <children>
                        <Label text="VITÓRIA!" textFill="#ffc107">
                           <font><Font size="32.0" /></font>
                        </Label>
                        <Label fx:id="labelVitoriaSubtitulo" text="Tu ganhaste!" textFill="#ffc107">
                           <font><Font size="22.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <Region VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </right>
   <center>
      <VBox alignment="CENTER" prefHeight="520.0" prefWidth="650.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <children>
            <Canvas fx:id="canvas" height="520.0" onMouseClicked="#canvasClicked" onMouseExited="#canvasExited" onMouseMoved="#canvasMoved" width="650.0" />
         </children>
      </VBox>
   </center>
</BorderPane>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #357b9c;" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.emlinha.JanelaController">
   <top>
      <HBox alignment="CENTER" prefHeight="80.0" prefWidth="900.0" style="-fx-background-color: transparent;" BorderPane.alignment="CENTER">
         <children>
            <HBox fx:id="boxEu" alignment="CENTER" prefWidth="220.0" spacing="10.0" style="-fx-border-color: #ffc107; -fx-border-radius: 30; -fx-border-width: 2; -fx-padding: 5 15 5 15;">
               <children>
                  <Circle fill="#ffc107" radius="15.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
                  <Label fx:id="labelTopoJogador1" text="Eu" textFill="#ffc107">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </Label>
               </children>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </HBox>
            
            <Region HBox.hgrow="ALWAYS" />
            
            <Label text="4 em Linha" textFill="WHITE">

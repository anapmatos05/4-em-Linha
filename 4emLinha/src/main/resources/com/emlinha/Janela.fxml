               </padding>
               <children>
                  <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #357b9c; -fx-border-color: #ffc107; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15;">
                     <padding>

                     </children>
                  </VBox>
                  <Region VBox.vgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#acaoAlternarPausa" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #5a8ca0; -fx-background-radius: 15; -fx-cursor: hand;" text="Voltar ao Jogo" textFill="WHITE">
                     <font><Font size="22.0" /></font>

                  </Label>
                  
                  <Label fx:id="labelAvisoColuna" alignment="CENTER" style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-padding: 8; -fx-background-radius: 5; -fx-font-weight: bold;" text="A Coluna está Cheia!&#10;Escolhe outra." textAlignment="CENTER" visible="false" wrapText="true">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>

                  <HBox alignment="CENTER" spacing="10.0">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                     <children>
                        <Button mnemonicParsing="false" onAction="#acaoGuardarJogo" prefWidth="100.0" style="-fx-background-color: #357b9c; -fx-text-fill: white; -fx-cursor: hand;" text="Gravar" />
                        <Button mnemonicParsing="false" onAction="#acaoCarregarJogo" prefWidth="100.0" style="-fx-background-color: #357b9c; -fx-text-fill: white; -fx-cursor: hand;" text="Carregar" />
                     </children>
